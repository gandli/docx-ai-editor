{
  "name": "docx-ai-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:ui": "vitest --ui",
    "benchmark": "node scripts/benchmark-api.js",
    "benchmark:full": "node scripts/benchmark-performance.js",
    "quality": "node scripts/code-quality-score.js",
    "lint": "eslint src/ --ext .js,.jsx --format json",
    "perf:report": "cat performance-results/benchmark-results.json | jq '.'"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@superdoc-dev/react": "^1.0.0-rc.2",
    "ai": "^6.0.116",
    "mammoth": "^1.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superdoc": "^1.18.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.0",
    "msw": "^2.12.11",
    "resize-observer-polyfill": "^1.5.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
